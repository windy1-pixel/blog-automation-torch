# Copy this file to ".env" and fill in your real values.
# Never commit the real ".env" file to git — it holds secrets.

# LLM provider:
#   "openai" (default) → hosted open-source model via any OpenAI-compatible API
#                        (OpenRouter, Groq, Cerebras…). Free tier, fast, no local hardware.
#   "ollama"           → fully local/offline (slow on CPU-only machines).
#   "claude"           → Anthropic (paid, highest quality) for scaling up.
LLM_PROVIDER=openai

# OpenAI-compatible provider (defaults target OpenRouter's free tier).
# Get a free key at https://openrouter.ai/keys
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# To use Groq instead: OPENAI_BASE_URL=https://api.groq.com/openai/v1  and a Groq model id.

# Local Ollama (only if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_NUM_CTX=8192

# Anthropic (Claude) — only if LLM_PROVIDER=claude. https://console.anthropic.com/settings/keys
CLAUDE_MODEL=claude-sonnet-5
ANTHROPIC_API_KEY=

# Server port (default 3000)
PORT=3000

# PostgreSQL connection string.
# Local dev: matches docker-compose.yml (run `docker compose up -d` first).
# Production (Coolify): Coolify generates this when you add a Postgres service —
# copy it from there instead of using the local value.
DATABASE_URL=postgres://blog_automation:local_dev_only@localhost:5432/blog_automation

# Sentry error tracking — create a free account at https://sentry.io,
# make a Node.js project, and paste its DSN here. Optional: app runs without it.
SENTRY_DSN=

# Torch Proxies credentials for SERP/competitor scraping (milestone 3)
TORCH_PROXY_HOST=
TORCH_PROXY_PORT=
TORCH_PROXY_USERNAME=
TORCH_PROXY_PASSWORD=

# Bright Data — https://brightdata.com (used later, for SERP/Reddit/forum scraping)
BRIGHTDATA_API_KEY=

# Google Ads API — used later, for real keyword volume/CPC data
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# Google Search Console — used later, for existing ranking data
GOOGLE_SEARCH_CONSOLE_CLIENT_EMAIL=
GOOGLE_SEARCH_CONSOLE_PRIVATE_KEY=
